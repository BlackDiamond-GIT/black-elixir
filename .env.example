# Локальна розробка — скопіюйте у .env
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# PostgreSQL (локально або окремо від Render)
# DATABASE_URL=postgres://user:password@localhost:5432/black_elixir

# Cloudinary (медіа з адмінки → CDN)
# Варіант 1 — один рядок:
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# Варіант 2 — окремі змінні:
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# WhatsApp для redirect /booking/out/
SITE_WHATSAPP=+420000000000

# Render (Starter web + Basic Postgres)
# DATABASE_URL, RENDER_EXTERNAL_HOSTNAME, PORT — задає Render автоматично
# SITE_DOMAIN — production домен (додається до ALLOWED_HOSTS і CSRF_TRUSTED_ORIGINS)
# SITE_DOMAIN=black-elixir.cz
# CLOUDINARY_* — додайте в Render Dashboard (Blueprint не перезаписує їх)
